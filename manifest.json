{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "RosterKit",
  "short_name": "RosterKit",
  "description": "Shift roster scheduling for any industry. No subscription. Works offline.",
  "version": "1.0.0",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait",
  "theme_color": "#0f1117",
  "background_color": "#0f1117",
  "icons": [
    {
      "src": "assets/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "assets/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "assets/screenshot-staff-placeholder.png",
      "sizes": "1290x2796",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Staff availability form"
    },
    {
      "src": "assets/screenshot-manager-placeholder.png",
      "sizes": "1290x2796",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Manager roster builder"
    }
  ],
  "shortcuts": [
    {
      "name": "Submit Availability",
      "short_name": "Availability",
      "description": "Open the staff availability form",
      "url": "./index.html?mode=staff",
      "icons": [{ "src": "assets/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Manager Mode",
      "short_name": "Manager",
      "description": "Open the manager roster builder",
      "url": "./index.html?mode=manager",
      "icons": [{ "src": "assets/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "categories": ["productivity", "business"],
  "prefer_related_applications": false
}
